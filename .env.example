# API ключ для геокодинга адресов (locationiq.com)
NEXT_PUBLIC_LOCATIONIQ_KEY=your_locationiq_key_here

# Адрес бэкенда для проксирования запросов через Next.js rewrites
# При локальной разработке: http://localhost:8080
# В Docker (имя контейнера бэкенда): http://book-store-app:8080
BACKEND_URL=http://book-store-app:8080
